{
    "name": "player-tracker",
    "version": "1.0.0",
    "private": true,
    "description": "PlayerTracker - Monorepo for athlete management platform",
    "workspaces": [
        "apps/*",
        "apps/mobile",
        "packages/*"
    ],
    "scripts": {
        "init": "./init.sh",
        "init:auto": "./init.sh --auto",
        "setup": "./init.sh",
        "setup:auto": "./init.sh --auto",
        "build": "turbo build",
        "build:packages": "turbo build --filter='./packages/*'",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "lint:fix": "turbo lint:fix",
        "format": "turbo format",
        "format:check": "turbo format:check",
        "format:write": "prettier --write .",
        "format:check:root": "prettier --check .",
        "type-check": "turbo type-check",
        "clean": "turbo clean && rm -rf node_modules",
        "test": "turbo test",
        "test:watch": "turbo test:watch",
        "test:e2e": "turbo test:e2e",
        "test:init": "./test-init.sh",
        "prisma:generate": "turbo prisma:generate",
        "prisma:push": "turbo prisma:push",
        "prisma:migrate": "turbo prisma:migrate",
        "prisma:reset": "turbo prisma:reset",
        "prisma:studio": "turbo prisma:studio",
        "docker:build": "docker-compose build",
        "docker:up": "docker-compose up -d",
        "docker:down": "docker-compose down",
        "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
        "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
        "turbo:update": "npx @turbo/codemod@latest update",
        "release": "pnpm validate && pnpm build && pnpm test",
        "precommit": "turbo format:check lint type-check",
        "prepare": "husky"
    },
    "devDependencies": {
        "@turbo/gen": "^2.6.0",
        "husky": "^9.1.7",
        "prettier": "^3.6.2",
        "turbo": "^2.6.0",
        "typescript": "^5.9.3"
    },
    "packageManager": "pnpm@10.12.2",
    "engines": {
        "node": ">=18.0.0",
        "pnpm": ">=10.0.0"
    },
    "pnpm": {
        "overrides": {
            "validator": ">=13.15.20",
            "form-data": ">=4.0.4",
            "axios": ">=1.12.0",
            "on-headers": ">=1.1.0",
            "@eslint/plugin-kit": ">=0.3.4",
            "@react-native-community/cli": ">=17.0.1",
            "tmp": ">=0.2.4",
            "react": "19.1.0",
            "react-dom": "19.1.0"
        }
    },
    "dependencies": {
        "tailwindcss": "^3.4.18"
    }
}
