# PNPM Configuration for React Native / Expo Monorepo

# Hoist React Native and Expo packages to workspace root for better Metro resolution
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=@babel/*

# Automatically install peer dependencies
auto-install-peers=true

# Strict peer dependencies (don't auto-install mismatched versions)
strict-peer-dependencies=false
