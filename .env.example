# =============================================================================
# PlayerTracker - Docker Compose Environment Variables
# =============================================================================
# Ce fichier contient UNIQUEMENT les variables nécessaires pour docker-compose
# Pour les variables de développement local des apps, voir:
#   - apps/api/.env.example (Backend NestJS)
#   - apps/web/.env.example (Frontend Next.js)
#   - apps/mobile/.env.example (Mobile Expo)
#
# Copier ce fichier vers .env et personnaliser les valeurs
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# Utilisé par docker-compose.dev.yml et docker-compose.yml
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=playertracker

# -----------------------------------------------------------------------------
# JWT (Production uniquement)
# Utilisé par docker-compose.yml pour le service API
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Docker Compose
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=playertracker
