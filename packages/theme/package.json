{
    "name": "@playertracker/theme",
    "version": "0.0.0",
    "private": true,
    "description": "Shared theme configuration and color system for PlayerTracker (cross-platform: Web & React Native)",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./web": "./src/web.ts",
        "./native": "./src/native.ts",
        "./tailwind": "./tailwind.base.config.ts",
        "./tailwind-native": "./tailwind.native.config.ts"
    },
    "scripts": {
        "lint": "eslint .",
        "type-check": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0"
    },
    "peerDependenciesMeta": {
        "next-themes": {
            "optional": true
        },
        "lucide-react": {
            "optional": true
        },
        "lucide-react-native": {
            "optional": true
        }
    },
    "devDependencies": {
        "@playertracker/config": "workspace:*",
        "@types/react": "^19.2.17",
        "@types/react-native": "^0.73.0",
        "eslint": "^9.39.1",
        "lucide-react": "^0.462.0",
        "lucide-react-native": "^0.516.0",
        "next-themes": "^0.4.6",
        "react-native": "^0.86.0",
        "typescript": "^5.9.3"
    }
}
