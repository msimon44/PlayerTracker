{
    "name": "@playertracker/utils",
    "version": "1.0.0",
    "description": "Shared utilities for PlayerTracker",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist/**"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "clean": "rm -rf dist",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"src/**/*.{ts,js,json}\"",
        "format:check": "prettier --check \"src/**/*.{ts,js,json}\""
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "date-fns": "^3.6.0",
        "tailwind-merge": "^2.6.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@playertracker/config": "workspace:*",
        "eslint": "^9.39.1",
        "typescript": "^5.9.3"
    }
}
