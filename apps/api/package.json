{
    "name": "@playertracker/api",
    "version": "1.0.0",
    "description": "PlayerTracker API - NestJS backend",
    "author": "PlayerTracker Team",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/src/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist",
        "generate:openapi": "ts-node -r tsconfig-paths/register src/generate-openapi.ts",
        "prisma:generate": "prisma generate",
        "prisma:push": "prisma db push && pnpm prisma:generate",
        "prisma:migrate": "prisma migrate dev && pnpm prisma:generate",
        "prisma:reset": "prisma migrate reset --force",
        "prisma:studio": "prisma studio",
        "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
    },
    "dependencies": {
        "@playertracker/utils": "workspace:*",
        "@nestjs/common": "^11.1.28",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.28",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/mapped-types": "^2.1.1",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.28",
        "@nestjs/swagger": "^11.4.6",
        "@nestjs/throttler": "^6.5.0",
        "@prisma/client": "^6.19.0",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "compression": "^1.8.1",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "helmet": "^8.3.0",
        "joi": "^17.13.3",
        "jsonwebtoken": "^9.0.3",
        "nestjs-zod": "^4.3.1",
        "passport": "^0.7.0",
        "passport-apple": "^2.0.2",
        "passport-google-oauth20": "^2.0.0",
        "passport-jwt": "^4.0.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "swagger-ui-express": "^5.0.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.6",
        "@eslint/js": "^9.39.1",
        "@nestjs/cli": "^11.0.24",
        "@nestjs/schematics": "^11.1.0",
        "@nestjs/testing": "^11.1.28",
        "@swc/cli": "^0.8.1",
        "@swc/core": "^1.15.46",
        "@types/bcrypt": "^5.0.2",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.19.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^24.10.0",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth20": "^2.0.17",
        "@types/passport-jwt": "^4.0.1",
        "@types/supertest": "^7.2.1",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^16.5.0",
        "jest": "^29.7.0",
        "prisma": "^6.19.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.12",
        "ts-loader": "^9.6.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.65.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
