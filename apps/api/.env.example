# Environment is automatically set by NestJS (development, production, test)

# Database (local development - use localhost)
# Pour Docker, utiliser db:5432 à la place de localhost:5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/playertracker?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here-change-this-in-production
JWT_EXPIRES_IN=24h

# Session secret for OAuth state management (fallback to JWT_SECRET if not set)
SESSION_SECRET=your-super-secret-session-key-here-change-this-in-production

# Encryption key for OAuth tokens (min 32 characters)
ENCRYPTION_KEY=your-32-character-or-longer-encryption-key-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Apple OAuth (pour Sign in with Apple)
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=/path/to/your/apple/private/key.p8
APPLE_CALLBACK_URL=http://localhost:3001/auth/apple/callback

# Frontend URL pour les redirections après OAuth
FRONTEND_URL=http://localhost:3000

# Mobile deep link URL for OAuth redirections
MOBILE_CALLBACK_URL=playertracker://auth/callback

# Server
PORT=3001

# URLs Frontend
WEB_URL=http://localhost:3000
MOBILE_URL=

# CORS - Allow localhost and local network access
CORS_ORIGIN=http://localhost:3000
